[run]
branch = True
source =
    packages/valory
omit =
    */tests/*
    */__pycache__/*
    */*_pb2.py
    */*_pb2_grpc.py

[report]
fail_under = 100
show_missing = True
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if TYPE_CHECKING:
    @abstractmethod
    pass

[html]
directory = htmlcov
